# Space Mish Configuration
# Copy this file to .env and adjust values

# Hub Configuration
HUB_PORT=3001
HUB_HOST=0.0.0.0
HUB_DB_PATH=./data/spacemish.db

# Web App
NEXT_PUBLIC_HUB_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# Agent Configuration
AGENT_PORT=3002
AGENT_HUB_URL=http://localhost:3001
AGENT_NAME=My Device
# Full filesystem access by default. Set specific paths to restrict:
# AGENT_APPROVED_DIRS=C:\Users\Bazil,D:\Projects
AGENT_APPROVED_DIRS=*
AGENT_CODE_SERVER_PORT=8080

# Discovery
MDNS_SERVICE_NAME=_spacemish._tcp
DISCOVERY_INTERVAL=5000
STALE_TIMEOUT=15000
OFFLINE_TIMEOUT=60000

# Remote access (Cloudflare Tunnel)
# After running: cloudflared tunnel --url http://localhost:3000
# Set the tunnel URL here so WebSocket connections work:
# NEXT_PUBLIC_HUB_URL=https://your-tunnel-id.trycloudflare.com
# NEXT_PUBLIC_WS_URL=wss://your-tunnel-id.trycloudflare.com

# Security (v1 - LAN mode)
AUTH_ENABLED=false
